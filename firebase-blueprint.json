{
  "entities": {
    "submission": {
      "title": "Submission",
      "description": "Instagram ID submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "password": { "type": "string" },
        "twoFactorKey": { "type": "string" },
        "twoFactorCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "password", "status", "userId", "createdAt"]
    },
    "withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "method", "status", "createdAt"]
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "submission",
      "description": "User submissions"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "withdrawal",
      "description": "User withdrawal requests"
    }
  }
}
